{
  "title": "Trading Analysis",
  "uid": "binance-trading",
  "schemaVersion": 38,
  "version": 5,
  "refresh": "5m",
  "time": { "from": "now-30d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "symbol",
        "label": "Symbol",
        "type": "query",
        "datasource": "BinanceBot",
        "query": "symbols",
        "definition": "symbols",
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "hide": 0,
        "current": {}
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "datasource": "BinanceBot",
        "enable": true,
        "hide": false,
        "iconColor": "#e0752d",
        "name": "Completed Trades",
        "query": "*"
      },
      {
        "datasource": "BinanceBot",
        "enable": true,
        "hide": false,
        "iconColor": "#5794F2",
        "name": "Trade Regions",
        "query": "trades_$symbol"
      },
      {
        "datasource": "BinanceBot",
        "enable": true,
        "hide": false,
        "iconColor": "#FF9830",
        "name": "Order Events",
        "query": "orders_$symbol"
      }
    ]
  },
  "panels": [
    {
      "id": 5,
      "title": "Price Chart — $symbol",
      "type": "candlestick",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 12 },
      "datasource": "BinanceBot",
      "targets": [
        {
          "target": "candles_$symbol",
          "type": "table",
          "refId": "A"
        },
        {
          "target": "buys_$symbol",
          "type": "timeserie",
          "refId": "B"
        },
        {
          "target": "sells_$symbol",
          "type": "timeserie",
          "refId": "C"
        }
      ],
      "options": {
        "mode": "candles+volume",
        "candleStyle": "candles",
        "colorStrategy": "open-close",
        "colors": {
          "up": "green",
          "down": "red",
          "flat": "gray"
        },
        "open": "Open",
        "high": "High",
        "low": "Low",
        "close": "Close",
        "volume": "Volume"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Volume" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "Volume" },
              { "id": "custom.scaleDistribution", "value": { "type": "linear" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^buys_" },
            "properties": [
              { "id": "custom.drawStyle", "value": "points" },
              { "id": "custom.pointSize", "value": 10 },
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^sells_" },
            "properties": [
              { "id": "custom.drawStyle", "value": "points" },
              { "id": "custom.pointSize", "value": 10 },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 0 }
            ]
          }
        ]
      }
    },
    {
      "id": 1,
      "title": "Profit per Trade (USDC)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "BinanceBot",
      "targets": [
        {
          "target": "profit",
          "type": "timeserie",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        }
      },
      "options": {
        "barWidth": 0.6,
        "groupWidth": 0.7
      }
    },
    {
      "id": 2,
      "title": "Cumulative Profit (USDC)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "BinanceBot",
      "targets": [
        {
          "target": "cumulative_profit",
          "type": "timeserie",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Profit % per Trade",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": "BinanceBot",
      "targets": [
        {
          "target": "profit_pct",
          "type": "timeserie",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Trade Volume (USDC)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": "BinanceBot",
      "targets": [
        {
          "target": "buy_qty",
          "type": "timeserie",
          "refId": "A"
        },
        {
          "target": "sell_qty",
          "type": "timeserie",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    }
  ]
}
